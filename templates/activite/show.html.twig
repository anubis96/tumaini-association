{% extends 'base.html.twig' %}
{% block title %}{{ activite.titre }} — MTU asbl{% endblock %}
{% block extra_head %}
<style>
    /* Dans votre fichier CSS global */
    @media (max-width: 640px) {
        .text-amber-600 {
            font-size: 0.9375rem; /* 15px sur mobile */
            line-height: 1.6;
        }
        
        .break-words {
            word-break: break-word;
            overflow-wrap: break-word;
            hyphens: auto;
        }
        
        /* Pour les très longs mots */
        .whitespace-normal {
            white-space: normal;
        }
    }
</style>
{% endblock %}

{% block body %}

<!-- Main content -->
<section class="relative pt-32 pb-0 overflow-hidden" style="background: radial-gradient(ellipse 60% 60% at 50% 0%, rgba(217,119,6,0.15) 0%, transparent 70%), #0a0704;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb - CORRIGÉ -->
        <div class="flex flex-wrap items-center gap-2 mb-8 text-sm">
            <a href="{{ path('app_home') }}" class="text-amber-700 hover:text-amber-500 transition-colors">Accueil</a>
            <span class="text-amber-800">/</span>
            <a href="{{ path('app_activites') }}" class="text-amber-700 hover:text-amber-500 transition-colors">Activités</a>
            <span class="text-amber-800">/</span>
            {# Supprimer line-clamp-1 qui cache le texte sur mobile #}
            <span class="text-amber-500 break-words max-w-[200px] sm:max-w-none">{{ activite.titre }}</span>
        </div>
        {% if activite.image_url %}
        <!-- Image de couverture -->
        <div class="mb-10 rounded-2xl overflow-hidden shadow-2xl shadow-amber-900/20 border border-amber-800/20">
            <img src="{{ activite.image_url }}" 
                alt="{{ activite.titre }}" 
                class="w-full h-48 sm:h-64 md:h-80 lg:h-96 object-cover transition-transform duration-700 hover:scale-105"
                loading="lazy">
        </div>
        {% else %}
        <!-- Icon de couverture -->
        <div class="mb-10 rounded-2xl overflow-hidden shadow-2xl shadow-amber-900/20 border border-amber-800/20">
            <div class="w-full h-48 sm:h-64 md:h-80 lg:h-96 flex items-center justify-center text-8xl">
                {{ activite.image_icon }}
            </div>
        </div>
        {% endif %}
        <!-- Header -->
        <div class="flex flex-col lg:flex-row gap-10 items-start pb-16">
            <div class="flex-1">
                <div class="flex flex-wrap items-center gap-3 mb-6">
                    <span class="bg-amber-900/40 border border-amber-800/40 text-amber-400 text-xs px-3 py-1.5 rounded-full font-medium">{{ activite.categorie }}</span>
                    <span class="badge-{{ activite.status }} text-xs font-semibold px-3 py-1.5 rounded-full">
                        {% if activite.status == 'en_cours' %}● En cours
                        {% elseif activite.status == 'termine' %}✓ Terminé
                        {% else %}◷ Planifié{% endif %}
                    </span>
                </div>
                <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl text-amber-100 font-bold leading-tight mb-6 break-words">
                    {{ activite.titre }}
                </h1>
                <!-- CORRIGÉ: taille de police plus grande sur mobile -->
                <p class="text-amber-500 text-base sm:text-lg lg:text-xl leading-relaxed break-words">
                    {{ activite.resume }}
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
    <span class="text-amber-600 text-sm font-medium mr-1">Partager :</span>
    
    <!-- WhatsApp -->
    <a href="https://wa.me/?text={{ (activite.titre ~ ' — ' ~ activite.resume ~ ' ' ~ app.request.uri)|url_encode }}"
       target="_blank"
       rel="noopener noreferrer"
       class="share-btn share-btn-whatsapp w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-0.5"
       aria-label="Partager sur WhatsApp"
       title="Partager sur WhatsApp">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
    </a>
    
    <!-- Facebook -->
    <a href="https://www.facebook.com/sharer/sharer.php?u={{ app.request.uri|url_encode }}"
       target="_blank"
       rel="noopener noreferrer"
       class="share-btn share-btn-facebook w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-0.5"
       aria-label="Partager sur Facebook"
       title="Partager sur Facebook">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
    </a>
    
    <!-- Twitter/X -->
    <a href="https://twitter.com/intent/tweet?text={{ (activite.titre ~ ' — ' ~ activite.resume)|url_encode }}&url={{ app.request.uri|url_encode }}"
       target="_blank"
       rel="noopener noreferrer"
       class="share-btn share-btn-twitter w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-0.5"
       aria-label="Partager sur Twitter"
       title="Partager sur Twitter/X">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
    </a>
    
    <!-- Copier le lien - CORRIGÉ -->
    <button onclick="copyLink()"
            id="copyButton"
            class="share-btn-copy w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-0.5 bg-amber-800/40 hover:bg-amber-700/60 text-amber-300 border border-amber-700/30 relative"
            aria-label="Copier le lien"
            title="Copier le lien"
            type="button">
        <!-- Icône de copie (par défaut) -->
        <svg id="copyIcon" class="w-5 h-5 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
        </svg>
        <!-- Icône de confirmation (cachée par défaut) -->
        <svg id="checkIcon" class="w-5 h-5 hidden transition-all duration-300 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
    </button>
</div>
            <!-- Big icon -->
            <div class="flex-shrink-0 w-36 h-36 rounded-3xl bg-gradient-to-br from-amber-900/40 to-orange-950/60 border border-amber-800/30 flex items-center justify-center text-8xl shadow-2xl shadow-amber-900/30 animate-float">
                {{ activite.image_icon }}
            </div>
        </div>
    </div>
</section>

<!-- Main content -->
<section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-12">

            <!-- Description -->
            <div class="lg:col-span-2 reveal">
                <h2 class="font-display text-2xl text-amber-200 font-bold mb-6 flex items-center gap-3">
                    <span class="w-8 h-0.5 bg-gradient-to-r from-amber-500 to-orange-500 inline-block"></span>
                    Description complète
                </h2>
                <!-- CORRIGÉ: meilleur padding et taille de police sur mobile -->
                <div class="text-amber-600 leading-relaxed text-sm sm:text-base space-y-4 bg-[#120c04] border border-amber-900/20 rounded-2xl p-5 sm:p-8">
                    {# Correction: permettre le word-wrap sur la description #}
                    <div class="break-words whitespace-normal">
                        {{ activite.description|nl2br }}
                    </div>
                </div>

                <!-- Impact section -->
                <div class="mt-10">
                    <h3 class="font-display text-xl text-amber-200 font-bold mb-5">Impact & Bénéficiaires</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-gradient-to-br from-amber-900/25 to-orange-950/30 border border-amber-800/20 rounded-2xl p-6 text-center">
                            <div class="gradient-text font-display text-3xl sm:text-4xl font-bold mb-2 break-words">{{ activite.participants }}</div>
                            <div class="text-amber-700 text-xs uppercase tracking-wider">Participants</div>
                        </div>
                        <div class="bg-gradient-to-br from-orange-900/25 to-amber-950/30 border border-orange-800/20 rounded-2xl p-6 text-center">
                            <div class="text-amber-300 font-bold text-base sm:text-lg mb-2 break-words">{{ activite.beneficiaires }}</div>
                            <div class="text-amber-700 text-xs uppercase tracking-wider">Bénéficiaires</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="reveal space-y-6">
                <!-- Info card -->
                <div class="bg-[#120c04] border border-amber-900/30 rounded-2xl p-5 sm:p-6">
                    <h3 class="text-amber-300 font-semibold text-sm uppercase tracking-wide mb-5">Informations</h3>
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <span class="text-lg flex-shrink-0">📅</span>
                            <div class="min-w-0 flex-1">
                                <div class="text-amber-600 text-xs mb-1">Date</div>
                                <div class="text-amber-300 text-sm font-medium break-words">{{ activite.date | date('d/m/Y') }}</div>
                            </div>
                        </div>
                        <div class="border-t border-amber-900/20"></div>
                        <div class="flex items-start gap-3">
                            <span class="text-lg flex-shrink-0">📍</span>
                            <div class="min-w-0 flex-1">
                                <div class="text-amber-600 text-xs mb-1">Lieu</div>
                                <div class="text-amber-300 text-sm font-medium break-words">{{ activite.lieu }}</div>
                            </div>
                        </div>
                        <div class="border-t border-amber-900/20"></div>
                        <div class="flex items-start gap-3">
                            <span class="text-lg flex-shrink-0">🏷️</span>
                            <div class="min-w-0 flex-1">
                                <div class="text-amber-600 text-xs mb-1">Catégorie</div>
                                <div class="text-amber-300 text-sm font-medium break-words">{{ activite.categorie }}</div>
                            </div>
                        </div>
                        <div class="border-t border-amber-900/20"></div>
                        <div class="flex items-start gap-3">
                            <span class="text-lg flex-shrink-0">📊</span>
                            <div>
                                <div class="text-amber-600 text-xs mb-1">Statut</div>
                                <span class="badge-{{ activite.status }} text-xs font-semibold px-2 py-1 rounded-full inline-block">
                                    {% if activite.status == 'en_cours' %}En cours{% elseif activite.status == 'termine' %}Terminé{% else %}Planifié{% endif %}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <a href="{{ path('app_contact') }}" class="btn-shine w-full block bg-gradient-to-r from-amber-600 to-orange-500 hover:from-amber-500 hover:to-orange-400 text-white font-bold py-4 rounded-xl text-center shadow-xl shadow-amber-900/40 transition-all hover:scale-105">
                    Nous soutenir
                </a>
                <a href="{{ path('app_activites') }}" class="w-full block border border-amber-800/40 hover:border-amber-600 text-amber-500 hover:text-amber-400 py-3 rounded-xl text-center text-sm transition-all hover:bg-amber-900/20">
                    ← Toutes les activités
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Other activities -->
{% if autres %}
<section class="py-16 border-t border-amber-900/20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl text-amber-200 font-bold mb-8">Autres activités</h2>
        <div class="grid md:grid-cols-3 gap-6">
            {% for a in autres %}
            <a href="{{ path('app_activite_show_slug', {slug: a.slug}) }}" class="reveal card-hover group block bg-[#120c04] border border-amber-900/30 hover:border-amber-700/40 rounded-xl p-6">
                <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">{{ a.image_icon }}</div>
                <div class="text-amber-500 text-xs font-medium mb-2">{{ a.categorie }}</div>
                <h3 class="text-amber-200 font-semibold text-sm mb-2 group-hover:text-amber-300 transition-colors line-clamp-2 leading-snug">{{ a.titre }}</h3>
                <span class="badge-{{ a.status }} text-xs px-2 py-0.5 rounded-full">
                    {% if a.status == 'en_cours' %}En cours{% elseif a.status == 'termine' %}Terminé{% else %}Planifié{% endif %}
                </span>
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}
{% block extra_scripts %}
{{ parent() }}
    <script>
    /**
    * Fonction principale pour copier le lien
    */
    function copyLink() {
        // Récupérer l'URL actuelle
        const url = window.location.href;
        
        // Récupérer les éléments du DOM
        const button = document.getElementById('copyButton');
        const copyIcon = document.getElementById('copyIcon');
        const checkIcon = document.getElementById('checkIcon');
        
        // Vérifier que les éléments existent
        if (!button || !copyIcon || !checkIcon) {
            console.error('Éléments de copie non trouvés');
            return;
        }
        
        // Tenter la copie avec l'API Clipboard moderne
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(url)
                .then(() => {
                    // Succès - afficher le feedback
                    showCopySuccess(button, copyIcon, checkIcon);
                })
                .catch((err) => {
                    console.error('Erreur clipboard API:', err);
                    // Fallback à la méthode traditionnelle
                    fallbackCopyLink(url, button, copyIcon, checkIcon);
                });
        } else {
            // API Clipboard non supportée
            fallbackCopyLink(url, button, copyIcon, checkIcon);
        }
    }

    /**
    * Méthode de copie de secours (pour navigateurs anciens)
    */
    function fallbackCopyLink(text, button, copyIcon, checkIcon) {
        // Créer un élément textarea temporaire
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.left = '-9999px';
        textarea.style.top = '-9999px';
        document.body.appendChild(textarea);
        
        // Sélectionner et copier
        textarea.select();
        textarea.setSelectionRange(0, 99999);
        
        try {
            const success = document.execCommand('copy');
            if (success) {
                showCopySuccess(button, copyIcon, checkIcon);
            } else {
                showCopyError();
            }
        } catch (err) {
            console.error('Erreur de copie:', err);
            showCopyError();
        }
        
        // Nettoyer
        document.body.removeChild(textarea);
    }

    /**
    * Afficher le feedback de succès
    */
    function showCopySuccess(button, copyIcon, checkIcon) {
        // Changer les icônes
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        
        // Ajouter l'effet visuel sur le bouton
        button.classList.add('copied');
        button.style.borderColor = '#10b981'; // Emeraude
        button.style.backgroundColor = 'rgba(16, 185, 129, 0.2)';
        
        // Afficher un toast de confirmation
        showToast('✅ Lien copié !');
        
        // Revenir à l'état normal après 2.5 secondes
        setTimeout(() => {
            copyIcon.classList.remove('hidden');
            checkIcon.classList.add('hidden');
            button.classList.remove('copied');
            button.style.borderColor = '';
            button.style.backgroundColor = '';
        }, 2500);
    }

    /**
    * Afficher un message d'erreur
    */
    function showCopyError() {
        showToast('❌ Impossible de copier le lien');
    }

    /**
    * Afficher un toast (notification) élégant
    */
    function showToast(message) {
        // Supprimer l'ancien toast s'il existe
        const oldToast = document.querySelector('.toast-copy');
        if (oldToast) {
            oldToast.remove();
        }
        
        // Créer le toast
        const toast = document.createElement('div');
        toast.className = 'toast-copy fixed bottom-8 left-1/2 transform -translate-x-1/2 bg-amber-900/95 backdrop-blur-sm border border-amber-700/50 text-amber-200 px-6 py-3 rounded-xl shadow-2xl z-50 text-sm font-medium transition-all duration-300';
        toast.textContent = message;
        
        // Style initial (invisible puis animation)
        toast.style.opacity = '0';
        toast.style.transform = 'translate(-50%, 20px)';
        document.body.appendChild(toast);
        
        // Forcer le reflow
        toast.offsetHeight;
        
        // Animation d'entrée
        toast.style.opacity = '1';
        toast.style.transform = 'translate(-50%, 0)';
        
        // Supprimer le toast après 3 secondes
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translate(-50%, -20px)';
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.remove();
                }
            }, 300);
        }, 3000);
    }

    // Gestionnaire d'événement pour le clic sur le bouton
    document.addEventListener('DOMContentLoaded', function() {
        const copyButton = document.getElementById('copyButton');
        if (copyButton) {
            copyButton.addEventListener('click', function(e) {
                e.preventDefault();
                copyLink();
            });
        }
    });

    // Support pour les navigateurs qui ne supportent pas les fonctions fléchées
    // (fallback pour IE et anciens navigateurs)
    if (typeof String.prototype.includes === 'undefined') {
        String.prototype.includes = function(search, start) {
            'use strict';
            if (typeof start !== 'number') {
                start = 0;
            }
            if (start + search.length > this.length) {
                return false;
            } else {
                return this.indexOf(search, start) !== -1;
            }
        };
    }
    </script>

    <style>
    /* Styles pour les boutons de partage */
    .share-btn-whatsapp {
        background: #25D366;
        color: white;
    }
    .share-btn-whatsapp:hover {
        background: #128C7E;
    }

    .share-btn-facebook {
        background: #1877F2;
        color: white;
    }
    .share-btn-facebook:hover {
        background: #0C63D4;
    }

    .share-btn-twitter {
        background: #000000;
        color: white;
    }
    .share-btn-twitter:hover {
        background: #333333;
    }

    .share-btn-copy {
        background: rgba(180, 83, 9, 0.3);
        color: #fbbf24;
        border: 1px solid rgba(180, 83, 9, 0.4);
    }
    .share-btn-copy:hover {
        background: rgba(180, 83, 9, 0.5);
        border-color: rgba(180, 83, 9, 0.6);
    }
    .share-btn-copy.copied {
        background: rgba(16, 185, 129, 0.2);
        border-color: #10b981;
        color: #34d399;
    }

    /* Animation du toast */
    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translate(-50%, 20px);
        }
        to {
            opacity: 1;
            transform: translate(-50%, 0);
        }
    }

    @keyframes slideDown {
        from {
            opacity: 1;
            transform: translate(-50%, 0);
        }
        to {
            opacity: 0;
            transform: translate(-50%, -20px);
        }
    }

    .toast-copy {
        animation: slideUp 0.3s ease-out forwards;
    }

    .toast-copy.removing {
        animation: slideDown 0.3s ease-in forwards;
    }

    /* Effet de pulse sur le bouton copié */
    @keyframes pulse-copy {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.1);
        }
    }

    .share-btn-copy.copied {
        animation: pulse-copy 0.5s ease 2;
    }
    </style>
{% endblock %}
{% endblock %}
