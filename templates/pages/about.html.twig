{% extends 'base.html.twig' %}
{% block title %}À propos — MTU asbl{% endblock %}

{% block body %}

<!-- Hero -->
<section class="relative pt-32 pb-24 overflow-hidden" style="background: radial-gradient(ellipse 80% 60% at 30% 30%, rgba(217,119,6,0.12) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 70% 70%, rgba(249,115,22,0.08) 0%, transparent 60%), #0a0704;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div>
                <div class="flex items-center gap-2 mb-6">
                    <div class="w-8 h-0.5 bg-gradient-to-r from-amber-500 to-orange-500"></div>
                    <span class="text-orange-400 text-xs font-semibold uppercase tracking-widest">Qui sommes-nous</span>
                </div>
                <h1 class="font-display text-5xl sm:text-6xl text-amber-100 font-bold leading-tight mb-6">
                    À propos de<br><span class="gradient-text">MTU asbl</span>
                </h1>
                <p class="text-amber-500 text-lg leading-relaxed">
                    <strong class="text-amber-400">MWANADAMU TUMAINI</strong> — «L'Humanité Espère» — est une association sans but lucratif établie en République Démocratique du Congo, dévouée à la paix et au développement des communautés du Sud-Kivu.
                </p>
            </div>

            <!-- Logo block -->
            <div class="hidden lg:flex justify-center">
                <div class="relative w-80 h-80">
                    <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-amber-900/30 via-orange-950/40 to-amber-900/20 border border-amber-700/20 flex items-center justify-center">
                        <div class="text-center">
                            <div class="text-8xl mb-4 animate-float">🕊️</div>
                            <div class="font-display text-amber-300 text-2xl font-bold">MTU</div>
                            <div class="text-amber-600 text-xs uppercase tracking-widest mt-1">asbl</div>
                            <div class="mt-3 text-amber-700 text-sm italic">« Mwanadamu Tumaini »</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Denomination & Siege -->
<section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-10">
            <div class="reveal bg-[#120c04] border border-amber-900/30 rounded-2xl p-8">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-600 to-orange-500 flex items-center justify-center text-2xl mb-5 shadow-lg">🏛️</div>
                <h2 class="font-display text-2xl text-amber-200 font-bold mb-4">Dénomination</h2>
                <p class="text-amber-600 leading-relaxed text-sm">
                    L'Association est dénommée : <strong class="text-amber-400">MWANADAMU TUMAINI «MTU» a.s.b.l</strong>. Ce nom, issu du swahili, signifie « L'Humanité Espère » — une promesse et un engagement envers les communautés que nous servons.
                </p>
            </div>

            <div class="reveal bg-[#120c04] border border-amber-900/30 rounded-2xl p-8">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-600 to-amber-500 flex items-center justify-center text-2xl mb-5 shadow-lg">📍</div>
                <h2 class="font-display text-2xl text-amber-200 font-bold mb-4">Siège social</h2>
                <p class="text-amber-600 leading-relaxed text-sm">
                    Le siège social est établi en <strong class="text-amber-400">République Démocratique du Congo</strong>, dans la Province du Sud-Kivu, Ville d'Uvira — Quartier Rombe 2, Avenue Orthodoxe.
                </p>
                <div class="mt-4 p-3 bg-amber-900/15 rounded-xl border border-amber-900/20">
                    <div class="text-amber-500 text-xs font-semibold">Rayon d'action</div>
                    <div class="text-amber-700 text-xs mt-1">Toute l'étendue de la province du Sud-Kivu et zones humanitaires</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Objectifs -->
<section class="py-20 bg-gradient-to-b from-[#0a0704] via-[#0d0904] to-[#0a0704]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14 reveal">
            <div class="flex items-center justify-center gap-2 mb-3">
                <div class="w-8 h-0.5 bg-gradient-to-r from-transparent to-amber-500"></div>
                <span class="text-orange-400 text-xs font-semibold uppercase tracking-widest">Notre mission</span>
                <div class="w-8 h-0.5 bg-gradient-to-l from-transparent to-amber-500"></div>
            </div>
            <h2 class="font-display text-4xl text-amber-100 font-bold">Nos objectifs</h2>
        </div>

        <!-- Objectif global -->
        <div class="reveal mb-10 relative bg-gradient-to-r from-amber-900/20 via-orange-950/30 to-amber-900/20 border border-amber-700/25 rounded-2xl p-10 overflow-hidden text-center">
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute top-0 left-1/3 w-64 h-64 bg-amber-600/8 rounded-full blur-3xl"></div>
            </div>
            <div class="relative z-10">
                <div class="text-5xl mb-5">🎯</div>
                <h3 class="font-display text-2xl text-amber-200 font-bold mb-4">Objectif Global</h3>
                <p class="text-amber-500 text-lg max-w-3xl mx-auto leading-relaxed">
                    Militer pour la <strong class="text-amber-400">consolidation de la paix</strong> en République Démocratique du Congo et pour le <strong class="text-amber-400">développement endogène</strong> des communautés tant rurales qu'urbaines.
                </p>
            </div>
        </div>

        <!-- Objectifs spécifiques -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% set objectifs = [
                {icon: '📰', title: 'Droit à l\'information', desc: 'Lutter pour le respect du Droit à l\'information et à l\'éducation dans toutes les communautés.'},
                {icon: '🛡️', title: 'Protection des victimes', desc: 'Lutter pour la protection des victimes de toutes les formes de violence et de discrimination.'},
                {icon: '🌿', title: 'Environnement & Agriculture', desc: 'Militer pour la protection de l\'environnement et la promotion de l\'agriculture moderne.'},
                {icon: '🏥', title: 'Santé pour tous', desc: 'Participer à la lutte pour la Santé pour tous, la prise en charge du VIH/SIDA, du paludisme et autres maladies.'},
                {icon: '💧', title: 'Hygiène publique', desc: 'Contribuer à la promotion de l\'hygiène publique dans les zones rurales et urbaines.'},
                {icon: '🕊️', title: 'Paix & Réconciliation', desc: 'Œuvrer pour la consolidation de la paix et la réconciliation intercommunautaire au Sud-Kivu.'},
            ] %}
            {% for obj in objectifs %}
            <div class="reveal card-hover bg-[#120c04] border border-amber-900/30 hover:border-amber-700/40 rounded-xl p-6">
                <div class="text-4xl mb-4">{{ obj.icon }}</div>
                <h4 class="text-amber-300 font-semibold mb-3">{{ obj.title }}</h4>
                <p class="text-amber-700 text-sm leading-relaxed">{{ obj.desc }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Team section -->
<section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14 reveal">
            <h2 class="font-display text-4xl text-amber-100 font-bold mb-3">L'équipe dirigeante</h2>
            <p class="text-amber-700">Des professionnels engagés pour la mission</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
            {% for membre in membres %}
            <div class="reveal card-hover group bg-[#120c04] border border-amber-900/30 hover:border-amber-700/40 rounded-xl p-6 text-center">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br {{ membre.couleur }} flex items-center justify-center text-white font-bold text-xl mx-auto mb-4 shadow-lg group-hover:scale-110 transition-transform">
                    {{ membre.initiales }}
                </div>
                <h3 class="text-amber-200 font-semibold text-sm">{{ membre.nom }}</h3>
                <p class="text-orange-500 text-xs mt-1">{{ membre.poste }}</p>
                <p class="text-amber-800 text-xs mt-3 line-clamp-2">{{ membre.specialite }}</p>
            </div>
            {% endfor %}
        </div>
        <div class="text-center mt-10 reveal">
            <a href="{{ path('app_membres') }}" class="btn-shine inline-flex items-center gap-2 bg-gradient-to-r from-amber-600 to-orange-500 text-white font-semibold px-8 py-4 rounded-xl shadow-xl shadow-amber-900/40 transition-all hover:scale-105">
                Voir tous les membres
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
        </div>
    </div>
</section>

{% endblock %}
