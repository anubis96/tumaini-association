{% extends 'base.html.twig' %}
{% block title %}Contact — MTU asbl{% endblock %}

{% block body %}

<!-- Header -->
<section class="relative pt-32 pb-20 overflow-hidden" style="background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(217,119,6,0.12) 0%, transparent 70%), #0a0704;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-2xl">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-0.5 bg-gradient-to-r from-amber-500 to-orange-500"></div>
                <span class="text-orange-400 text-xs font-semibold uppercase tracking-widest">Nous joindre</span>
            </div>
            <h1 class="font-display text-5xl sm:text-6xl text-amber-100 font-bold mb-4">Contactez-nous</h1>
            <p class="text-amber-600 text-lg">Une question, un partenariat ou une urgence humanitaire ? Nous sommes disponibles.</p>
        </div>
    </div>
</section>

<!-- Contact content -->
<section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12">

            <!-- Contact Info -->
            <div class="lg:col-span-2 space-y-6 reveal">
                <div class="bg-[#120c04] border border-amber-900/30 rounded-2xl p-7">
                    <h3 class="font-display text-xl text-amber-200 font-bold mb-6">Nos coordonnées</h3>
                    <div class="space-y-5">
                        <a href="tel:+24397482155" class="flex items-start gap-4 group">
                            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-amber-600 to-orange-500 flex items-center justify-center text-white text-lg flex-shrink-0 shadow-lg group-hover:scale-105 transition-transform">📞</div>
                            <div>
                                <div class="text-amber-600 text-xs uppercase tracking-wide mb-1">Téléphone</div>
                                <div class="text-amber-300 font-semibold">+243 97 482 155</div>
                            </div>
                        </a>
                        <div class="border-t border-amber-900/20"></div>
                        <a href="mailto:mawanadamutumaini@gmail.com" class="flex items-start gap-4 group">
                            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-orange-600 to-amber-500 flex items-center justify-center text-white text-lg flex-shrink-0 shadow-lg group-hover:scale-105 transition-transform">✉️</div>
                            <div>
                                <div class="text-amber-600 text-xs uppercase tracking-wide mb-1">Email</div>
                                <div class="text-amber-300 font-semibold text-sm break-all">mawanadamutumaini@gmail.com</div>
                            </div>
                        </a>
                        <div class="border-t border-amber-900/20"></div>
                        <div class="flex items-start gap-4">
                            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-amber-700 to-orange-600 flex items-center justify-center text-white text-lg flex-shrink-0 shadow-lg">📍</div>
                            <div>
                                <div class="text-amber-600 text-xs uppercase tracking-wide mb-1">Adresse physique</div>
                                <div class="text-amber-300 text-sm leading-relaxed">Ville d'Uvira<br>Quartier Rombe 2<br>Avenue Orthodoxe<br><span class="text-amber-600">Province du Sud-Kivu, RDC</span></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hours -->
                <div class="bg-[#120c04] border border-amber-900/30 rounded-2xl p-7">
                    <h3 class="text-amber-300 font-semibold mb-4">Disponibilité</h3>
                    <div class="space-y-2">
                        <div class="flex justify-between text-sm">
                            <span class="text-amber-700">Lun – Ven</span>
                            <span class="text-amber-400 font-medium">08h00 – 17h00</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-amber-700">Samedi</span>
                            <span class="text-amber-400 font-medium">09h00 – 12h00</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-amber-700">Dimanche</span>
                            <span class="text-amber-800">Fermé</span>
                        </div>
                    </div>
                    <div class="mt-5 p-3 bg-orange-900/15 border border-orange-900/20 rounded-xl">
                        <div class="text-orange-400 text-xs font-semibold mb-1">🚨 Urgences humanitaires</div>
                        <div class="text-amber-700 text-xs">Disponibles 24h/24 pour les situations d'urgence</div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="lg:col-span-3 reveal">
                <div class="bg-[#120c04] border border-amber-900/30 rounded-2xl p-8">
                    <h3 class="font-display text-2xl text-amber-200 font-bold mb-7">Envoyez-nous un message</h3>

                    <form class="space-y-5" id="contact-form">
                        <div class="grid sm:grid-cols-2 gap-5">
                            <div>
                                <label class="block text-amber-600 text-xs uppercase tracking-wide mb-2">Prénom & Nom</label>
                                <input type="text" placeholder="Jean BUKURU"
                                    class="w-full bg-[#1a1008] border border-amber-900/40 focus:border-amber-600 text-amber-200 placeholder-amber-900 rounded-xl px-4 py-3 text-sm outline-none transition-colors focus:ring-1 focus:ring-amber-700/50">
                            </div>
                            <div>
                                <label class="block text-amber-600 text-xs uppercase tracking-wide mb-2">Email</label>
                                <input type="email" placeholder="vous@exemple.com"
                                    class="w-full bg-[#1a1008] border border-amber-900/40 focus:border-amber-600 text-amber-200 placeholder-amber-900 rounded-xl px-4 py-3 text-sm outline-none transition-colors focus:ring-1 focus:ring-amber-700/50">
                            </div>
                        </div>

                        <div>
                            <label class="block text-amber-600 text-xs uppercase tracking-wide mb-2">Téléphone</label>
                            <input type="tel" placeholder="+243 ..."
                                class="w-full bg-[#1a1008] border border-amber-900/40 focus:border-amber-600 text-amber-200 placeholder-amber-900 rounded-xl px-4 py-3 text-sm outline-none transition-colors focus:ring-1 focus:ring-amber-700/50">
                        </div>

                        <div>
                            <label class="block text-amber-600 text-xs uppercase tracking-wide mb-2">Sujet</label>
                            <select class="w-full bg-[#1a1008] border border-amber-900/40 focus:border-amber-600 text-amber-400 rounded-xl px-4 py-3 text-sm outline-none transition-colors focus:ring-1 focus:ring-amber-700/50 appearance-none">
                                <option value="" class="bg-[#1a1008]">Sélectionnez un sujet...</option>
                                <option value="partenariat" class="bg-[#1a1008]">Partenariat</option>
                                <option value="volontariat" class="bg-[#1a1008]">Volontariat</option>
                                <option value="don" class="bg-[#1a1008]">Don / Financement</option>
                                <option value="urgence" class="bg-[#1a1008]">Urgence humanitaire</option>
                                <option value="autre" class="bg-[#1a1008]">Autre</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-amber-600 text-xs uppercase tracking-wide mb-2">Message</label>
                            <textarea rows="5" placeholder="Décrivez votre message ici..."
                                class="w-full bg-[#1a1008] border border-amber-900/40 focus:border-amber-600 text-amber-200 placeholder-amber-900 rounded-xl px-4 py-3 text-sm outline-none transition-colors focus:ring-1 focus:ring-amber-700/50 resize-none"></textarea>
                        </div>

                        <button type="button" onclick="handleSubmit()" class="btn-shine w-full bg-gradient-to-r from-amber-600 to-orange-500 hover:from-amber-500 hover:to-orange-400 text-white font-bold py-4 rounded-xl shadow-xl shadow-amber-900/40 transition-all hover:scale-[1.02] text-sm">
                            Envoyer le message →
                        </button>
                    </form>

                    <div id="success-msg" class="hidden mt-5 p-4 bg-green-900/20 border border-green-800/30 rounded-xl text-green-400 text-sm text-center">
                        ✓ Message envoyé ! Nous vous répondrons dans les plus brefs délais.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}

{% block extra_scripts %}
<script>
function handleSubmit() {
    document.getElementById('contact-form').style.opacity = '0.5';
    setTimeout(() => {
        document.getElementById('contact-form').style.display = 'none';
        document.getElementById('success-msg').classList.remove('hidden');
    }, 800);
}
</script>
{% endblock %}
