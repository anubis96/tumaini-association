{% extends 'base.html.twig' %}
{% block title %}Notre équipe — MTU asbl{% endblock %}

{% block body %}

<!-- Header -->
<section class="relative pt-32 pb-20 overflow-hidden" style="background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(217,119,6,0.12) 0%, transparent 70%), #0a0704;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex items-center gap-2 mb-4 text-sm">
            <a href="{{ path('app_home') }}" class="text-amber-700 hover:text-amber-500">Accueil</a>
            <span class="text-amber-800">/</span>
            <span class="text-amber-400">Membres</span>
        </div>
        <h1 class="font-display text-5xl sm:text-6xl text-amber-100 font-bold mb-4">Notre équipe</h1>
        <p class="text-amber-600 text-lg max-w-xl">Des femmes et des hommes engagés au service des communautés du Sud-Kivu.</p>
    </div>
</section>

<section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for membre in membres %}
            <div class="reveal card-hover group bg-[#120c04] border border-amber-900/30 hover:border-amber-700/40 rounded-2xl overflow-hidden">

                <!-- Card top gradient -->
                <div class="h-28 bg-gradient-to-br {{ membre.couleur }} relative overflow-hidden opacity-30 group-hover:opacity-50 transition-opacity">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#120c04]"></div>
                </div>

                <!-- Avatar -->
                <div class="relative -mt-14 px-6">
                    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br {{ membre.couleur }} flex items-center justify-center text-white font-bold text-2xl shadow-2xl shadow-amber-900/40 border-4 border-[#120c04] group-hover:scale-105 transition-transform">
                        {{ membre.initiales }}
                    </div>
                </div>

                <div class="p-6 pt-4">
                    <h3 class="font-display text-amber-100 text-xl font-bold mb-1 group-hover:text-amber-300 transition-colors">{{ membre.nom }}</h3>
                    <p class="text-orange-400 text-sm font-medium mb-4">{{ membre.poste }}</p>
                    <p class="text-amber-700 text-sm leading-relaxed mb-6 line-clamp-3">{{ membre.bio }}</p>

                    <!-- Tags -->
                    <div class="flex flex-wrap gap-2 mb-6">
                        <span class="bg-amber-900/20 border border-amber-800/30 text-amber-600 text-xs px-3 py-1 rounded-full">{{ membre.specialite }}</span>
                        <span class="bg-amber-900/15 text-amber-800 text-xs px-3 py-1 rounded-full">Depuis {{ membre.anciennete }}</span>
                    </div>

                    <!-- Contact -->
                    <div class="flex items-center gap-3 pt-4 border-t border-amber-900/20">
                        <a href="mailto:{{ membre.email }}" class="flex items-center gap-2 text-amber-700 hover:text-amber-400 text-xs transition-colors group/email">
                            <span class="w-7 h-7 rounded-lg bg-amber-900/30 group-hover/email:bg-amber-800/50 flex items-center justify-center transition-all">✉️</span>
                            <span class="hidden sm:block truncate max-w-[140px]">{{ membre.email }}</span>
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}
